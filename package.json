{
  "name": "desafio-backend-nodejs",
  "version": "1.0.0",
  "description": "Desafio técnico backend — Atendimento WhatsApp com IA (Meta + OpenAI)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "token:dev": "tsx src/scripts/create-dev-token.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/jwt": "^10.1.0",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "bullmq": "^5.78.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.11.1",
    "langchain": "^1.4.4",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "//dependencias-sugeridas": "Adicione conforme sua solução: express|fastify|hono, drizzle-orm, postgres, bullmq, ioredis, openai, pino, zod, @aws-sdk/client-sqs ...",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
