# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-troque-pela-sua-chave
OPENAI_MODEL=gpt-4o-mini

# ─── Meta WhatsApp Cloud API ──────────────────────────────
# Token de verificação do handshake do webhook (você define; use o mesmo no painel da Meta).
META_VERIFY_TOKEN=meu-verify-token-secreto
# App Secret — usado para validar a assinatura X-Hub-Signature-256.
# Com o mock, mantenha IGUAL ao META_APP_SECRET do docker-compose.yml.
META_APP_SECRET=super-secret-app-secret-trocar
# Token de acesso para enviar mensagens. Com o mock, qualquer valor serve.
META_TOKEN=mock-token
# Base da API da Meta. Mock: http://localhost:8001  |  Real: https://graph.facebook.com/v21.0
META_API_BASE_URL=http://localhost:8001
# ID do número de telefone (origem dos envios). Mock aceita qualquer valor.
META_PHONE_NUMBER_ID=123456789012345

# ─── Banco de dados ───────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/atendimento

# ─── Fila ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
QUEUE_NAME=inbound-messages
# Se optar por SQS/LocalStack:
# AWS_ENDPOINT_URL=http://localhost:4566
# SQS_QUEUE_URL=http://localhost:4566/000000000000/atendimento-jobs

# ─── App ──────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
JWT_SECRET=dev-secret-change-me-in-production
DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001
